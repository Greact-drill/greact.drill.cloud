// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema 

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "frontend"]
}

// ------------------------------------
// Public Schema (default)
// ------------------------------------

model History {
  id        Int      @id @default(autoincrement())
  edge      String   @db.VarChar(100)
  timestamp DateTime
  tag       String   @db.VarChar(100)
  value     Float
  createdAt DateTime @default(now())

  @@index([edge])
  @@index([timestamp])
  @@index([tag])
  @@index([edge, tag])
  @@index([edge, timestamp])
  @@index([edge, tag, timestamp])
  @@map("history")
  @@schema("public")
}

model TagAlarmLog {
  id                 Int      @id @default(autoincrement())
  edge_id            String   @db.VarChar(100)
  tag_id             String   @db.VarChar(100)
  tag_name           String   @db.VarChar(255)
  journal_type       String   @default("indicator") @db.VarChar(20) // 'indicator' | 'alarm'
  value              Float
  min_limit          Float
  max_limit          Float
  alarm_type         String   @db.VarChar(20) // 'min' | 'max'
  unit_of_measurement String  @db.VarChar(50)
  timestamp          DateTime
  createdAt          DateTime @default(now())

  @@index([edge_id])
  @@index([tag_id])
  @@index([timestamp])
  @@index([edge_id, timestamp])
  @@index([edge_id, journal_type, timestamp])
  @@map("tag_alarm_log")
  @@schema("public")
}

/// Журнал срабатываний виджета «Авария» (переход значения в 1)
model AlarmWidgetLog {
  id        Int      @id @default(autoincrement())
  edge_id   String   @db.VarChar(100)
  tag_id    String   @db.VarChar(100)
  tag_name  String   @db.VarChar(255)
  value     Float    @default(1)
  timestamp DateTime
  createdAt DateTime @default(now())

  @@index([edge_id])
  @@index([tag_id])
  @@index([timestamp])
  @@index([edge_id, timestamp])
  @@map("alarm_widget_log")
  @@schema("public")
}

model Current {
  id        Int      @id @default(autoincrement())
  edge      String   @db.VarChar(100)
  tag       String   @db.VarChar(100)
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([edge, tag])
  @@index([edge])
  @@index([tag])
  @@map("current")
  @@schema("public")
}

model Edge {
  id        String  @id @db.VarChar(100)
  name      String
  parent_id String? @db.VarChar(100)
  tag_ids   String[] @default([])

  // Self-referential relation for hierarchy
  parent   Edge?  @relation("EdgeToParent", fields: [parent_id], references: [id])
  children Edge[] @relation("EdgeToParent")

  // Customizations
  edge_customizations edge_customization[]
  tag_customizations  tag_customization[]

  @@index([name])
  @@index([parent_id])
  @@map("edge")
  @@schema("public")
}

model Tag {
  id                  String              @id @db.VarChar(100)
  name                String
  tag_group           String?
  min                 Int
  max                 Int
  comment             String
  unit_of_measurement String
  precision           Int?                // Количество цифр после запятой (для числовых тегов, кроме boolean)
  edge_ids            String[]            @default([])
  tag_customizations  tag_customization[]

  @@index([name])
  @@map("tag")
  @@schema("public")
}

// ------------------------------------
// Frontend Schema
// ------------------------------------

model edge_customization {
  id      Int    @id @default(autoincrement())
  edge_id String @db.VarChar(100)
  key     String
  value   String
  edge    Edge   @relation(fields: [edge_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([edge_id, key])
  @@index([edge_id])
  @@map("edge_customization")
  @@schema("frontend")
}

model tag_customization {
  id      Int    @id @default(autoincrement())
  edge_id String @db.VarChar(100)
  tag_id  String @db.VarChar(100)
  key     String
  value   String
  edge    Edge   @relation(fields: [edge_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tag     Tag    @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([edge_id, tag_id, key])
  @@map("tag_customization")
  @@schema("frontend")
}
